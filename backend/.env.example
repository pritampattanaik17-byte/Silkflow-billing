# SilkFlow Wholesale Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is listed in .gitignore.

PORT=5000
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
JWT_SECRET="generate-a-strong-random-secret-at-least-64-characters"
GROQ_API_KEY="your-groq-api-key-here"

# Optional: set to 'production' for Vercel deployments
# NODE_ENV=production

# Optional: additional allowed CORS origin for frontend
# FRONTEND_URL=https://your-custom-domain.com
